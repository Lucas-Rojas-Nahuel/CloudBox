<%- include('../partials/head') %>
<div
  class="min-h-screen overflow-y-auto w-full bg-background flex items-center justify-center p-4 relative"
>
  <div
    class="absolute inset-0 bg-gradient-to-br from-primary/10 via-background to-secondary/10"
  ></div>
  <div class="absolute inset-0">
    <div
      class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/20 rounded-full blur-3xl"
    ></div>
    <div
      class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-secondary/20 rounded-full blur-3xl"
    ></div>
  </div>

  <div class="w-full max-w-md relative z-10">
    <div class="text-center mb-8">
      <div
        class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-primary to-secondary mb-4 shadow-2xl shadow-primary/30"
      >
        <p class="w-8 h-8 text-white"></p>
      </div>
      <h1 class="text-4xl font-bold text-foreground mb-2">CloudBox</h1>
      <p class="text-muted-foreground">Inicia sesión en tu cuenta</p>
    </div>

    <div
      class="p-8 bg-card rounded-2xl bg-white/5 backdrop-blur-xl border border-white/10"
    >
      <form class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-foreground mb-2">
            Correo electrónico
          </label>
          <div class="relative w-full">
            <div
              class="absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground"
            >
              sd
            </div>
            <input
              class="w-full bg-input border border-border rounded-xl px-4 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all pl-10"
              type="email"
              placeholder="tu@email.com"
              value="{email}"
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-foreground mb-2">
            Contraseña
          </label>
          <div class="relative w-full">
            <div
              class="absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground"
            >
              sd
            </div>
            <input
              class="w-full bg-input border border-border rounded-xl px-4 py-2.5 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all pl-10"
              type="password"
              placeholder="••••••••"
              value="{password}"
            />
          </div>
        </div>

        <div class="flex items-center justify-between text-sm">
          <label class="flex items-center gap-2 cursor-pointer">
            <input
              type="checkbox"
              class="w-4 h-4 rounded border-border bg-input"
            />
            <span class="text-muted-foreground">Recordarme</span>
          </label>
          <a class="text-primary hover:underline">
            ¿Olvidaste tu contraseña?
          </a>
        </div>

        <button
          type="submit"
          variant="primary"
          class="hover:scale-103  rounded-xl font-medium transition-all duration-200 flex items-center gap-2 justify-center w-full bg-primary text-primary-foreground hover:opacity-90 shadow-lg shadow-primary/20 px-4 py-2.5 cursor-pointer"
        >
          Iniciar sesión
        </button>

        <div class="text-center">
          <p class="text-sm text-muted-foreground">
            ¿No tienes cuenta?
            <a class="text-primary hover:underline font-medium">
              Regístrate aquí
            </a>
          </p>
        </div>
      </form>
    </div>

    <p class="text-center text-xs text-muted-foreground mt-8">
      Al continuar, aceptas nuestros Términos de Servicio y Política de
      Privacidad
    </p>
  </div>
</div>
<%- include('../partials/footer') %>
